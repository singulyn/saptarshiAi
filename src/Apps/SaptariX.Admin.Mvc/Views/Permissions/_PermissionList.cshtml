@using SaptariX.Admin.Mvc.ViewModels.Permissions
@model PermissionListViewModel
@{
    var totalPages = Math.Max(1, Model.TotalPages);
    var previousDisabled = Model.PageNumber <= 1 ? "disabled" : string.Empty;
    var nextDisabled = Model.PageNumber >= totalPages ? "disabled" : string.Empty;
}

@if (!Model.HasItems)
{
    <div class="users-empty-state">
        <strong>No permissions found</strong>
        <span>Adjust the search or create a custom permission.</span>
    </div>
}
else
{
    <div class="table-responsive users-table-wrapper organizations-table-wrapper org-table-scroll">
        <table class="table table-hover align-middle users-table organizations-table mb-0">
            <thead>
                <tr>
                    <th scope="col"><button type="button" class="users-sort-button" data-permissions-sort="Name">Permission</button></th>
                    <th scope="col"><button type="button" class="users-sort-button" data-permissions-sort="Group">Group</button></th>
                    <th scope="col">Description</th>
                    <th scope="col">Source</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var permission in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="users-person">
                                <span class="users-avatar" aria-hidden="true"><i class="fa-solid fa-key" aria-hidden="true"></i></span>
                                <div>
                                    <strong>@permission.Name</strong>
                                    <span>@permission.DisplayName</span>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge text-bg-light users-role-badge">@permission.Group</span></td>
                        <td>@permission.Description</td>
                        <td><span class="badge @(permission.IsSystem ? "text-bg-primary" : "text-bg-secondary")">@(permission.IsSystem ? "System" : "Custom")</span></td>
                        <td>
                            <div class="users-actions organizations-actions">
                                <button type="button" class="btn btn-light btn-sm fa-icon-btn" data-permissions-action="edit" data-permission-id="@permission.Id" aria-label="Edit @permission.Name" @(permission.IsSystem ? "disabled" : string.Empty)>
                                    <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="btn btn-light btn-sm fa-icon-btn text-danger" data-permissions-action="delete" data-permission-id="@permission.Id" aria-label="Delete @permission.Name" @(permission.IsSystem ? "disabled" : string.Empty)>
                                    <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="users-table-footer">
    <span>@Model.TotalCount permission@(Model.TotalCount == 1 ? string.Empty : "s")</span>
    <div class="sx-pagination">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-permissions-page="@(Model.PageNumber - 1)" @previousDisabled>Previous</button>
        <button type="button" class="btn btn-outline-secondary btn-sm active" aria-current="page">@Model.PageNumber</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-permissions-page="@(Model.PageNumber + 1)" @nextDisabled>Next</button>
    </div>
</div>
