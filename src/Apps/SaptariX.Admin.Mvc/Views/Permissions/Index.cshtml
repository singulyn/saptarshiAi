@using SaptariX.Admin.Mvc.ViewModels.Permissions
@model PermissionListViewModel
@{
    ViewData["Title"] = "Permissions";
    ViewData["ActiveMenu"] = "/Permissions";
    ViewData["HideBreadcrumb"] = true;
    var formModel = PermissionFormViewModel.Empty();
}

<section class="page-section users-page organizations-page access-page"
         data-permissions-root
         data-list-url="/Permissions/List"
         data-get-url="/Permissions/GetById"
         data-create-url="/Permissions/Create"
         data-update-url="/Permissions/Update"
         data-delete-url="/Permissions/Delete">
    @Html.AntiForgeryToken()

    <div class="section-header organizations-page-header">
        <div class="organizations-page-titlebar">
            <button type="button" class="organizations-back-button d-none" data-permissions-back-to-list aria-label="Back to permission list">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            </button>
            <h1>Permissions</h1>
        </div>
        <div class="organizations-page-actions">
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-permissions-open-create>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                <span>Create Permission</span>
            </button>
        </div>
    </div>

    <div class="users-alert-host" data-permissions-alert></div>

    <div class="organizations-content-stack">
        <div data-permissions-list-panel>
            <div class="card users-card organizations-card">
                <div class="card-body organizations-list-body p-0">
                    <form class="organizations-filter access-list-filter sx-form-compact" data-permissions-filter-form>
                        <div class="organizations-filter-field organizations-filter-search">
                            <label class="visually-hidden" for="PermissionsSearch">Search permissions</label>
                            <div class="input-group input-group-sm sx-table-filter-search">
                                <span class="input-group-text" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input class="form-control form-control-sm" id="PermissionsSearch" type="search" name="Search" placeholder="Search by permission or group" autocomplete="off" />
                            </div>
                        </div>
                        <div class="organizations-filter-field">
                            <label class="visually-hidden" for="PermissionsGroup">Group</label>
                            <input class="form-control form-control-sm sx-table-filter-select" id="PermissionsGroup" type="text" name="Group" placeholder="Group" autocomplete="off" />
                        </div>
                        <div class="sx-table-filter-actions organizations-filter-actions">
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" type="submit"><i class="fa-solid fa-filter" aria-hidden="true"></i><span>Apply</span></button>
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" type="button" data-permissions-clear-filters><i class="fa-solid fa-rotate-left" aria-hidden="true"></i><span>Reset</span></button>
                        </div>
                    </form>
                    <div class="users-loading-state d-none" data-permissions-loading>
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>Loading permissions</span>
                    </div>
                    <div data-permissions-list-host>
                        <partial name="_PermissionList" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-none" data-permissions-form-panel>
            <partial name="_PermissionForm" model="formModel" />
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/permissions.js" asp-append-version="true"></script>
}
