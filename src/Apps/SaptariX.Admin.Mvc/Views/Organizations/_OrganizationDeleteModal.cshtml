<div class="modal fade" id="organizationDeleteModal" tabindex="-1" aria-labelledby="organizationDeleteModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content users-confirm-modal">
            <div class="modal-header">
                <h2 class="modal-title fs-6" id="organizationDeleteModalTitle">Delete Organization</h2>
