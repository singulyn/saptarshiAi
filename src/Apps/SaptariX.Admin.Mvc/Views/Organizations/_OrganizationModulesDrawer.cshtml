<div class="offcanvas offcanvas-end ui-drawer organization-drawer organization-modules-drawer"
     tabindex="-1"
     id="organizationModulesDrawer"
     aria-labelledby="organizationModulesDrawerTitle"
     data-organization-drawer="modules">
    <div class="offcanvas-header ui-drawer-header organization-modules-header">
        <div>
            <p class="section-kicker mb-1">Organization</p>
            <h2 class="offcanvas-title" id="organizationModulesDrawerTitle">Organization Module Access</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body ui-drawer-body organization-modules-body">
        <div class="ui-user-summary organization-drawer-summary organization-module-summary-card">
            <span class="users-avatar users-avatar-lg" data-organization-drawer-avatar>M</span>
            <div class="organization-module-summary-copy">
                <strong data-organization-drawer-name>Select organization</strong>
                <span data-organization-drawer-meta>Module enablement preview</span>
            </div>
            <span class="organization-module-summary-icon" aria-hidden="true">
                <i class="fa-regular fa-building"></i>
            </span>
        </div>

        <div class="input-group input-group-sm user-permission-search organization-module-search">
            <span class="input-group-text" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input class="form-control" type="search" placeholder="Search modules..." data-organization-drawer-search autocomplete="off" aria-label="Search modules" />
        </div>

        <div class="organization-modules-toolbar">
            <span class="organization-modules-total" data-organization-modules-count>9 of 16 modules selected</span>
            <div class="organization-drawer-command-row">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-organization-select-all-modules>Select all</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-organization-clear-modules>Clear all</button>
            </div>
        </div>

        <div class="organization-module-groups" data-organization-modules-list>
            <section class="organization-module-group" data-module-group="access">
                <div class="organization-module-group-header">
                    <span class="organization-module-group-icon"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i></span>
                    <strong>Access &amp; Identity</strong>
                    <span class="organization-module-group-count" data-module-group-count="access">5 / 5</span>
                    <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
                </div>
                <div class="organization-module-group-list">
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="access">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-id-badge" aria-hidden="true"></i>
                        <span class="form-check-label">Identity</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="access">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-lock" aria-hidden="true"></i>
                        <span class="form-check-label">Access Control</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="access">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                        <span class="form-check-label">Users</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="access">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-users-gear" aria-hidden="true"></i>
                        <span class="form-check-label">Roles</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="access">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-key" aria-hidden="true"></i>
                        <span class="form-check-label">Permissions</span>
                    </label>
                </div>
            </section>

            <section class="organization-module-group" data-module-group="automation">
                <div class="organization-module-group-header">
                    <span class="organization-module-group-icon"><i class="fa-solid fa-bolt" aria-hidden="true"></i></span>
                    <strong>Automation &amp; Operations</strong>
                    <span class="organization-module-group-count" data-module-group-count="automation">2 / 3</span>
                    <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
                </div>
                <div class="organization-module-group-list">
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="automation">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-diagram-project" aria-hidden="true"></i>
                        <span class="form-check-label">Workflow</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="automation">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-regular fa-rectangle-list" aria-hidden="true"></i>
                        <span class="form-check-label">Dynamic Forms</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="automation">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-solid fa-table" aria-hidden="true"></i>
                        <span class="form-check-label">Dynamic Tables</span>
                    </label>
                </div>
            </section>

            <section class="organization-module-group" data-module-group="insights">
                <div class="organization-module-group-header">
                    <span class="organization-module-group-icon"><i class="fa-solid fa-chart-simple" aria-hidden="true"></i></span>
                    <strong>Insights &amp; Communication</strong>
                    <span class="organization-module-group-count" data-module-group-count="insights">1 / 2</span>
                    <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
                </div>
                <div class="organization-module-group-list">
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="insights">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-chart-pie" aria-hidden="true"></i>
                        <span class="form-check-label">Reports</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="insights">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-regular fa-bell" aria-hidden="true"></i>
                        <span class="form-check-label">Notifications</span>
                    </label>
                </div>
            </section>

            <section class="organization-module-group" data-module-group="business">
                <div class="organization-module-group-header">
                    <span class="organization-module-group-icon"><i class="fa-solid fa-briefcase" aria-hidden="true"></i></span>
                    <strong>Business &amp; Management</strong>
                    <span class="organization-module-group-count" data-module-group-count="business">1 / 6</span>
                    <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
                </div>
                <div class="organization-module-group-list">
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-regular fa-folder" aria-hidden="true"></i>
                        <span class="form-check-label">Files</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-regular fa-credit-card" aria-hidden="true"></i>
                        <span class="form-check-label">Payments</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-solid fa-receipt" aria-hidden="true"></i>
                        <span class="form-check-label">Billing</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-regular fa-comment-dots" aria-hidden="true"></i>
                        <span class="form-check-label">AI Assistant</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" />
                        <i class="fa-regular fa-newspaper" aria-hidden="true"></i>
                        <span class="form-check-label">CMS</span>
                    </label>
                    <label class="form-check organization-drawer-row organization-module-row" data-drawer-row data-module-group-item="business">
                        <input class="form-check-input" type="checkbox" checked />
                        <i class="fa-solid fa-cubes" aria-hidden="true"></i>
                        <span class="form-check-label">App Builder</span>
                    </label>
                </div>
            </section>
        </div>
    </div>

    <div class="ui-drawer-footer organization-modules-footer">
        <span class="organization-modules-footer-count" data-organization-modules-footer-count>9 of 16 modules selected</span>
        <div class="organization-modules-footer-actions">
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-organization-drawer-save>Save Modules</button>
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" data-bs-dismiss="offcanvas">Cancel</button>
        </div>
    </div>
</div>
