<div class="card users-card organizations-card">
    <div class="card-header users-card-header organizations-card-header">
        <div>
            <h2 class="users-card-title">Organization List</h2>
            <p class="users-card-subtitle">Search, filter, sort, and manage organization setup surfaces.</p>
        </div>
    </div>

    <div class="card-body organizations-list-body p-0">
        <form class="organizations-filter sx-table-filter-row" data-organizations-filter-form>
            <div class="input-group input-group-sm sx-table-filter-search organizations-filter-search">
                <span class="input-group-text">Search</span>
                <input class="form-control form-control-sm" type="search" name="Search" placeholder="Name, code, email, or domain" autocomplete="off" />
            </div>
            <select class="form-select form-select-sm sx-table-filter-select" name="Status" aria-label="Status filter">
                <option value="">All statuses</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
                <option value="Suspended">Suspended</option>
                <option value="Trial">Trial</option>
                <option value="Archived">Archived</option>
            </select>
            <select class="form-select form-select-sm sx-table-filter-select" name="Type" aria-label="Organization type filter">
                <option value="">All types</option>
                <option value="Platform">Platform</option>
                <option value="Customer">Customer</option>
                <option value="Partner">Partner</option>
                <option value="Internal">Internal</option>
                <option value="Vendor">Vendor</option>
                <option value="Demo">Demo</option>
                <option value="Trial">Trial</option>
            </select>
            <select class="form-select form-select-sm sx-table-filter-select" name="Plan" aria-label="Plan filter">
                <option value="">All plans</option>
                <option value="Free">Free</option>
                <option value="Starter">Starter</option>
                <option value="Professional">Professional</option>
                <option value="Enterprise">Enterprise</option>
                <option value="Custom">Custom</option>
            </select>
            <select class="form-select form-select-sm sx-table-filter-select" name="Industry" aria-label="Industry filter">
                <option value="">All industries</option>
                <option value="Technology">Technology</option>
                <option value="Healthcare">Healthcare</option>
                <option value="Finance">Finance</option>
                <option value="Education">Education</option>
                <option value="Retail">Retail</option>
                <option value="Manufacturing">Manufacturing</option>
                <option value="Logistics">Logistics</option>
                <option value="Other">Other</option>
            </select>
            <input class="form-control form-control-sm" type="text" name="CreatedRange" placeholder="Created date range" aria-label="Created date range placeholder" />
            <div class="sx-table-filter-actions organizations-filter-actions">
                <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" type="submit">Apply</button>
                <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" type="button" data-organizations-reset-filters>Reset</button>
            </div>
        </form>

        <div class="users-loading-state d-none" data-organizations-loading>
            <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
            <span>Loading organizations</span>
        </div>

