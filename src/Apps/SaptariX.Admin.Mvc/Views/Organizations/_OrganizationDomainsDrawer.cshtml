<div class="offcanvas offcanvas-end ui-drawer organization-drawer organization-drawer-wide"
     tabindex="-1"
     id="organizationDomainsDrawer"
     aria-labelledby="organizationDomainsDrawerTitle"
     data-organization-drawer="domains">
    <div class="offcanvas-header ui-drawer-header">
        <div>
            <p class="section-kicker mb-1">Organization</p>
            <h2 class="offcanvas-title" id="organizationDomainsDrawerTitle">Organization Domains</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body ui-drawer-body">
        <div class="ui-user-summary organization-drawer-summary">
            <span class="users-avatar users-avatar-lg" data-organization-drawer-avatar>D</span>
            <div>
                <strong data-organization-drawer-name>Select organization</strong>
                <span data-organization-drawer-meta>Domain and subdomain preview</span>
            </div>
        </div>

        <div class="card sx-card sx-card-compact organization-inline-card">
            <div class="card-body">
                <div class="organization-section-heading">
                    <h3>Inline Create Domain</h3>
                    <span>Add a preview row to the drawer table</span>
                </div>
                <form class="organization-inline-domain-form" data-organization-domain-form>
                    <input class="form-control form-control-sm" name="Domain" placeholder="app.example.com" aria-label="Domain" />
                    <select class="form-select form-select-sm" name="DomainType" aria-label="Domain type">
                        <option>Custom</option>
                        <option>Primary</option>
                        <option>Subdomain</option>
                        <option>Redirect</option>
                    </select>
                    <select class="form-select form-select-sm" name="Status" aria-label="Domain status">
                        <option>Active</option>
                        <option>Inactive</option>
                    </select>
                    <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" type="submit">Add Domain</button>
                </form>
            </div>
        </div>

        <div class="table-responsive organization-drawer-table">
            <table class="table table-hover align-middle sx-table mb-0">
                <thead>
                    <tr>
                        <th>Domain</th>
                        <th>Type</th>
                        <th>Primary</th>
                        <th>Verification</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody data-organization-domains-body>
                    <tr>
                        <td>platform.saptarix.local</td>
                        <td><span class="badge text-bg-light users-role-badge">Primary</span></td>
                        <td><div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked aria-label="Primary domain" /></div></td>
                        <td><span class="badge text-bg-success">Verified</span></td>
                        <td><span class="badge text-bg-success">Active</span></td>
                        <td class="text-end"><button class="btn btn-light btn-sm fa-icon-btn text-danger" type="button" data-organization-domain-delete aria-label="Delete domain"><i class="fa-solid fa-trash" aria-hidden="true"></i></button></td>
                    </tr>
                    <tr>
                        <td>admin.saptarix.app</td>
                        <td><span class="badge text-bg-light users-role-badge">Subdomain</span></td>
                        <td><div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" aria-label="Primary domain" /></div></td>
                        <td><span class="badge text-bg-warning">Pending</span></td>
                        <td><span class="badge text-bg-success">Active</span></td>
                        <td class="text-end"><button class="btn btn-light btn-sm fa-icon-btn text-danger" type="button" data-organization-domain-delete aria-label="Delete domain"><i class="fa-solid fa-trash" aria-hidden="true"></i></button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="ui-drawer-footer">
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-organization-drawer-save>Save Domains</button>
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" data-bs-dismiss="offcanvas">Cancel</button>
    </div>
</div>
