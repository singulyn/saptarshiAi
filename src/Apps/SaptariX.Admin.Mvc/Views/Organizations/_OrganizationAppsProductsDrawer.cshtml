<div class="offcanvas offcanvas-end ui-drawer organization-drawer"
     tabindex="-1"
     id="organizationAppsProductsDrawer"
     aria-labelledby="organizationAppsProductsDrawerTitle"
     data-organization-drawer="apps">
    <div class="offcanvas-header ui-drawer-header">
        <div>
            <p class="section-kicker mb-1">Organization</p>
            <h2 class="offcanvas-title" id="organizationAppsProductsDrawerTitle">Apps &amp; Products Mapping</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body ui-drawer-body">
        <div class="ui-user-summary organization-drawer-summary">
            <span class="users-avatar users-avatar-lg" data-organization-drawer-avatar>A</span>
            <div>
                <strong data-organization-drawer-name>Select organization</strong>
                <span data-organization-drawer-meta>Apps and product access preview</span>
            </div>
        </div>

        <div class="input-group input-group-sm user-permission-search">
            <span class="input-group-text">Search</span>
            <input class="form-control" type="search" placeholder="Search apps or products" data-organization-drawer-search autocomplete="off" />
        </div>

        <div class="accordion" id="organizationAppsProductsAccordion">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#organizationCoreApps" aria-expanded="true" aria-controls="organizationCoreApps">
                        Core Apps <span class="badge text-bg-light ms-2">5</span>
                    </button>
                </h3>
                <div id="organizationCoreApps" class="accordion-collapse collapse show" data-bs-parent="#organizationAppsProductsAccordion">
                    <div class="accordion-body">
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">Admin Platform <small class="text-muted d-block">Enterprise control surface</small></span>
                            <span class="badge text-bg-dark ms-auto">Enterprise</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">App Builder <small class="text-muted d-block">Low-code app composition</small></span>
                            <span class="badge text-bg-primary ms-auto">Professional</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">Dynamic Forms <small class="text-muted d-block">Form capture and routing</small></span>
                            <span class="badge text-bg-primary ms-auto">Starter</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" />
                            <span class="form-check-label">Dynamic Tables <small class="text-muted d-block">Configurable data grids</small></span>
                            <span class="badge text-bg-light ms-auto">Custom</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">Workflow Automation <small class="text-muted d-block">Approval and background flows</small></span>
                            <span class="badge text-bg-dark ms-auto">Enterprise</span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#organizationGrowthApps" aria-expanded="false" aria-controls="organizationGrowthApps">
                        Growth Products <span class="badge text-bg-light ms-2">6</span>
                    </button>
                </h3>
                <div id="organizationGrowthApps" class="accordion-collapse collapse" data-bs-parent="#organizationAppsProductsAccordion">
                    <div class="accordion-body">
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">Reports &amp; Analytics</span>
                            <span class="badge text-bg-primary ms-auto">Professional</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" />
                            <span class="form-check-label">CMS</span>
                            <span class="badge text-bg-light ms-auto">Custom</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" />
                            <span class="form-check-label">Billing</span>
                            <span class="badge text-bg-dark ms-auto">Enterprise</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" />
                            <span class="form-check-label">AI Assistant</span>
                            <span class="badge text-bg-warning ms-auto">Preview</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" checked />
                            <span class="form-check-label">Customer Portal</span>
                            <span class="badge text-bg-primary ms-auto">Starter</span>
                        </label>
                        <label class="form-check organization-drawer-row" data-drawer-row>
                            <input class="form-check-input" type="checkbox" />
                            <span class="form-check-label">Mobile API</span>
                            <span class="badge text-bg-primary ms-auto">Professional</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ui-drawer-footer">
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-organization-drawer-save>Save Mapping</button>
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" data-bs-dismiss="offcanvas">Cancel</button>
    </div>
</div>
