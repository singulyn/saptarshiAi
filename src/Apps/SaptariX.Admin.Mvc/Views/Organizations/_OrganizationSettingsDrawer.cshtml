<div class="offcanvas offcanvas-end ui-drawer organization-drawer organization-settings-drawer"
     tabindex="-1"
     id="organizationSettingsDrawer"
     aria-labelledby="organizationSettingsDrawerTitle"
     data-organization-drawer="settings">
    <div class="offcanvas-header ui-drawer-header organization-settings-header">
        <div>
            <p class="section-kicker mb-1">Organization</p>
            <h2 class="offcanvas-title" id="organizationSettingsDrawerTitle">Organization Settings</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body ui-drawer-body organization-settings-body">
        <div class="ui-user-summary organization-drawer-summary organization-settings-summary">
            <span class="users-avatar users-avatar-lg" data-organization-drawer-avatar>S</span>
            <div>
                <strong data-organization-drawer-name>Select organization</strong>
                <span data-organization-drawer-meta>Key-value configuration preview</span>
            </div>
        </div>

        <div class="accordion organization-settings-accordion" id="organizationSettingsAccordion">
            <div class="accordion-item organization-settings-card">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#organizationGeneralSettings" aria-expanded="false" aria-controls="organizationGeneralSettings">
                        General Settings
                    </button>
                </h3>
                <div id="organizationGeneralSettings" class="accordion-collapse collapse" data-bs-parent="#organizationSettingsAccordion">
                    <div class="accordion-body">
                        <div class="organization-settings-table" role="table" aria-label="General settings">
                            <div class="organization-settings-table-head" role="row">
                                <span role="columnheader">Key</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Type</span>
                            </div>
                            <div class="organization-settings-row" role="row" data-drawer-row>
                                <span class="organization-settings-key" role="cell">default.language</span>
                                <span class="organization-settings-value" role="cell">en-IN</span>
                                <span class="organization-settings-type" role="cell">String</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="accordion-item organization-settings-card">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#organizationSecuritySettings" aria-expanded="false" aria-controls="organizationSecuritySettings">
                        Security Settings
                    </button>
                </h3>
                <div id="organizationSecuritySettings" class="accordion-collapse collapse" data-bs-parent="#organizationSettingsAccordion">
                    <div class="accordion-body">
                        <div class="organization-settings-table" role="table" aria-label="Security settings">
                            <div class="organization-settings-table-head" role="row">
                                <span role="columnheader">Key</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Type</span>
                            </div>
                            <div class="organization-settings-row" role="row" data-drawer-row>
                                <span class="organization-settings-key" role="cell">security.mfa.required</span>
                                <span class="organization-settings-value" role="cell">true</span>
                                <span class="organization-settings-type" role="cell">Boolean</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="accordion-item organization-settings-card">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#organizationBrandingSettings" aria-expanded="true" aria-controls="organizationBrandingSettings">
                        Branding Settings
                    </button>
                </h3>
                <div id="organizationBrandingSettings" class="accordion-collapse collapse show" data-bs-parent="#organizationSettingsAccordion">
                    <div class="accordion-body">
                        <div class="organization-settings-table" role="table" aria-label="Branding settings">
                            <div class="organization-settings-table-head" role="row">
                                <span role="columnheader">Key</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Type</span>
                            </div>
                            <div class="organization-settings-row" role="row" data-drawer-row>
                                <span class="organization-settings-key" role="cell">branding.primaryColor</span>
                                <span class="organization-settings-value organization-settings-color-value" role="cell">
                                    <span class="organization-settings-color-swatch" aria-hidden="true"></span>
                                    <span>#000d0f</span>
                                </span>
                                <span class="organization-settings-type" role="cell">String</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="accordion-item organization-settings-card">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#organizationNotificationSettings" aria-expanded="false" aria-controls="organizationNotificationSettings">
                        Notification Settings
                    </button>
                </h3>
                <div id="organizationNotificationSettings" class="accordion-collapse collapse" data-bs-parent="#organizationSettingsAccordion">
                    <div class="accordion-body">
                        <div class="organization-settings-table" role="table" aria-label="Notification settings">
                            <div class="organization-settings-table-head" role="row">
                                <span role="columnheader">Key</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Type</span>
                            </div>
                            <div class="organization-settings-row" role="row" data-drawer-row>
                                <span class="organization-settings-key" role="cell">notifications.email.enabled</span>
                                <span class="organization-settings-value" role="cell">true</span>
                                <span class="organization-settings-type" role="cell">Boolean</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="accordion-item organization-settings-card">
                <h3 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#organizationFeatureSettings" aria-expanded="false" aria-controls="organizationFeatureSettings">
                        Feature Flags
                    </button>
                </h3>
                <div id="organizationFeatureSettings" class="accordion-collapse collapse" data-bs-parent="#organizationSettingsAccordion">
                    <div class="accordion-body">
                        <div class="organization-settings-table" role="table" aria-label="Feature flags">
                            <div class="organization-settings-table-head" role="row">
                                <span role="columnheader">Key</span>
                                <span role="columnheader">Value</span>
                                <span role="columnheader">Type</span>
                            </div>
                            <div class="organization-settings-row" role="row" data-drawer-row>
                                <span class="organization-settings-key" role="cell">features.aiAssistant</span>
                                <span class="organization-settings-value" role="cell">false</span>
                                <span class="organization-settings-type" role="cell">Boolean</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ui-drawer-footer organization-settings-footer">
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-organization-drawer-save>Save Settings</button>
        <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" data-bs-dismiss="offcanvas">Cancel</button>
    </div>
</div>
