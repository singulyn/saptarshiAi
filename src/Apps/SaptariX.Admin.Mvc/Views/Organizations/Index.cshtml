@model SaptariX.Admin.Mvc.Models.AdminPageViewModel
@{
    ViewData["Title"] = "Organizations";
    ViewData["ActiveMenu"] = "/Organizations";
    ViewData["HideBreadcrumb"] = true;
}

<section class="page-section users-page organizations-page"
         data-organizations-root>
    @Html.AntiForgeryToken()

    <div class="section-header organizations-page-header">
        <div>
            <h1>Organizations</h1>
            <p class="section-summary">Manage your customer, partner, and platform organizations. Monitor activity, plans, and user access.</p>
        </div>
        <div class="organizations-page-actions">
            <button type="button" class="ui-adv-btn ui-adv-btn-paper ui-adv-btn-sage" data-organizations-export>
                <i class="fa-solid fa-arrow-up-from-bracket" aria-hidden="true"></i>
                <span>Export</span>
            </button>
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-organizations-open-create>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                <span>Create Organization</span>
            </button>
        </div>
    </div>

    <div class="users-alert-host" data-organizations-alert></div>

    <div class="organizations-content-stack">
        <div data-organizations-list-panel>
            <partial name="_OrganizationList" />
        </div>

        <div class="d-none" data-organizations-form-panel>
            <partial name="_OrganizationForm" />
        </div>
    </div>

    <partial name="_OrganizationAppsProductsDrawer" />
    <partial name="_OrganizationModulesDrawer" />
    <partial name="_OrganizationDomainsDrawer" />
    <partial name="_OrganizationSettingsDrawer" />
    <partial name="_OrganizationDeleteModal" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/organizations.js" asp-append-version="true"></script>
}
