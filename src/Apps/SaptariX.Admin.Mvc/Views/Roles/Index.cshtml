@using SaptariX.Admin.Mvc.ViewModels.Roles
@model RoleListViewModel
@{
    ViewData["Title"] = "Roles";
    ViewData["ActiveMenu"] = "/Roles";
    ViewData["HideBreadcrumb"] = true;
    var formModel = RoleFormViewModel.Empty(Model.OrganizationId);
    var permissionsModel = RolePermissionViewModel.Empty(Model.OrganizationId);
}

<section class="page-section users-page organizations-page access-page"
         data-roles-root
         data-organization-id="@Model.OrganizationId"
         data-list-url="/Roles/List"
         data-get-url="/Roles/GetById"
         data-create-url="/Roles/Create"
         data-update-url="/Roles/Update"
         data-delete-url="/Roles/SoftDelete"
         data-permissions-url="/Roles/GetPermissions"
         data-save-permissions-url="/Roles/SavePermissions">
    @Html.AntiForgeryToken()

    <div class="section-header organizations-page-header">
        <div class="organizations-page-titlebar">
            <button type="button" class="organizations-back-button d-none" data-roles-back-to-list aria-label="Back to role list">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            </button>
            <h1>Roles</h1>
        </div>
        <div class="organizations-page-actions">
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-roles-open-create>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                <span>Create Role</span>
            </button>
        </div>
    </div>

    <div class="users-alert-host" data-roles-alert></div>

    <div class="organizations-content-stack">
        <div data-roles-list-panel>
            <div class="card users-card organizations-card">
                <div class="card-body organizations-list-body p-0">
                    <form class="organizations-filter sx-form-compact" data-roles-filter-form>
                        <div class="organizations-filter-field organizations-filter-search">
                            <label class="visually-hidden" for="RolesSearch">Search roles</label>
                            <div class="input-group input-group-sm sx-table-filter-search">
                                <span class="input-group-text" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input class="form-control form-control-sm" id="RolesSearch" type="search" name="Search" placeholder="Search by role or description" autocomplete="off" />
                            </div>
                        </div>
                        <div class="organizations-filter-field">
                            <label class="visually-hidden" for="RolesStatus">Status</label>
                            <select class="form-select form-select-sm sx-table-filter-select" id="RolesStatus" name="Status" aria-label="Status filter" data-sx-select-minimal>
                                <option value="">All statuses</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="sx-table-filter-actions organizations-filter-actions">
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" type="submit"><i class="fa-solid fa-filter" aria-hidden="true"></i><span>Apply</span></button>
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" type="button" data-roles-clear-filters><i class="fa-solid fa-rotate-left" aria-hidden="true"></i><span>Reset</span></button>
                        </div>
                    </form>
                    <div class="users-loading-state d-none" data-roles-loading>
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>Loading roles</span>
                    </div>
                    <div data-roles-list-host>
                        <partial name="_RoleList" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-none" data-roles-form-panel>
            <partial name="_RoleForm" model="formModel" />
        </div>
    </div>

    <div data-role-permissions-host>
        <partial name="_RolePermissionsDrawer" model="permissionsModel" />
    </div>

    <div class="modal fade" id="roleDeleteModal" tabindex="-1" aria-labelledby="roleDeleteModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content users-confirm-modal">
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="roleDeleteModalTitle">Delete Role</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">Are you sure you want to delete this role?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger btn-sm" data-roles-confirm-delete>Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/roles.js" asp-append-version="true"></script>
}
