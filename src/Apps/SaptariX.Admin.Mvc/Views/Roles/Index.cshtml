@using SaptariX.Admin.Mvc.ViewModels.Roles
@using SaptariX.Platform.AccessControl.Permissions
@model RoleListViewModel
@{
    ViewData["Title"] = "Roles";
    ViewData["ActiveMenu"] = "/Roles";
    var formModel = RoleFormViewModel.Empty(Model.OrganizationId);
    var permissionsModel = RolePermissionViewModel.Empty(Model.OrganizationId);
}

<section class="page-section users-page access-page"
         data-roles-root
         data-organization-id="@Model.OrganizationId"
         data-list-url="/Roles/List"
         data-get-url="/Roles/GetById"
         data-create-url="/Roles/Create"
         data-update-url="/Roles/Update"
         data-delete-url="/Roles/SoftDelete"
         data-permissions-url="/Roles/GetPermissions"
         data-save-permissions-url="/Roles/SavePermissions">
    @Html.AntiForgeryToken()

    <div class="section-header">
        <div>
            <p class="section-kicker">Access Control</p>
            <h1>Roles</h1>
            <p class="section-summary">Manage organization roles and the permissions attached to each role.</p>
        </div>
        <span class="permission-pill">@PlatformPermissions.RolesView</span>
    </div>

    <div class="users-alert-host" data-roles-alert></div>

    <ul class="nav nav-tabs users-tabs" id="rolesTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="roles-list-tab" data-bs-toggle="tab" data-bs-target="#roles-list-pane" type="button" role="tab" aria-controls="roles-list-pane" aria-selected="true">
                Role List
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="roles-form-tab" data-bs-toggle="tab" data-bs-target="#roles-form-pane" type="button" role="tab" aria-controls="roles-form-pane" aria-selected="false">
                Create Role
            </button>
        </li>
    </ul>

    <div class="tab-content users-tab-content" id="rolesTabsContent">
        <div class="tab-pane fade show active" id="roles-list-pane" role="tabpanel" aria-labelledby="roles-list-tab" tabindex="0">
            <div class="card users-card">
                <div class="card-header users-card-header">
                    <div>
                        <h2 class="users-card-title">Role List</h2>
                        <p class="users-card-subtitle">Search, filter, sort, and manage role access surfaces.</p>
                    </div>
                    <form class="users-filter sx-table-filter-row" data-roles-filter-form>
                        <div class="input-group input-group-sm users-search sx-table-filter-search">
                            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i></span>
                            <input class="form-control form-control-sm" type="search" name="Search" placeholder="Name or description" autocomplete="off" />
                        </div>
                        <select class="form-select form-select-sm users-status-filter sx-table-filter-select" name="Status" aria-label="Status filter">
                            <option value="">All statuses</option>
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <div class="sx-table-filter-actions">
                            <button class="btn btn-primary btn-sm" type="submit"><i class="fa-solid fa-filter" aria-hidden="true"></i> Apply</button>
                            <button class="btn btn-outline-secondary btn-sm" type="button" data-roles-clear-filters>Reset</button>
                        </div>
                    </form>
                </div>
                <div class="card-body p-0">
                    <div class="users-loading-state d-none" data-roles-loading>
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>Loading roles</span>
                    </div>
                    <div data-roles-list-host>
                        <partial name="_RoleList" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="roles-form-pane" role="tabpanel" aria-labelledby="roles-form-tab" tabindex="0">
            <partial name="_RoleForm" model="formModel" />
        </div>
    </div>

    <div data-role-permissions-host>
        <partial name="_RolePermissionsDrawer" model="permissionsModel" />
    </div>

    <div class="modal fade" id="roleDeleteModal" tabindex="-1" aria-labelledby="roleDeleteModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content users-confirm-modal">
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="roleDeleteModalTitle">Delete Role</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">Are you sure you want to delete this role?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger btn-sm" data-roles-confirm-delete>Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/roles.js" asp-append-version="true"></script>
}
