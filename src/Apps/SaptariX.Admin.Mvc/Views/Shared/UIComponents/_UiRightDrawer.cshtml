<div class="offcanvas offcanvas-end ui-drawer" tabindex="-1" id="uiDemoDrawer" aria-labelledby="uiDemoDrawerTitle">
    <div class="offcanvas-header ui-drawer-header">
        <div>
            <p class="section-kicker mb-1">Drawer</p>
            <h2 class="offcanvas-title" id="uiDemoDrawerTitle">User Permissions</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body ui-drawer-body">
        <div class="ui-user-summary">
            <span class="users-avatar users-avatar-lg">A</span>
            <div><strong>Aarav Sharma</strong><span>aarav@saptarix.local</span></div>
        </div>
        <input class="form-control form-control-sm my-3" type="search" placeholder="Search permissions" />
        <div class="accordion" id="uiPermissionAccordion">
            <div class="accordion-item">
                <h3 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#uiPermissionUsers">Users</button>
                </h3>
                <div id="uiPermissionUsers" class="accordion-collapse collapse show" data-bs-parent="#uiPermissionAccordion">
                    <div class="accordion-body">
                        <label class="form-check"><input class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Users.View</span></label>
                        <label class="form-check"><input class="form-check-input" type="checkbox" /> <span class="form-check-label">Users.Update</span></label>
                        <label class="form-check"><input class="form-check-input" type="checkbox" /> <span class="form-check-label">Users.ManagePermissions</span></label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="ui-drawer-footer">
        <button type="button" class="btn btn-primary btn-sm">Save Permissions</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="offcanvas">Cancel</button>
    </div>
</div>
