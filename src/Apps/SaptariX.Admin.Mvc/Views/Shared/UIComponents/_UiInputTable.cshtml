<div class="card ui-demo-card" data-ui-input-table>
    <div class="card-header ui-card-header">
        <div>
            <h3 class="ui-card-title">Input Table</h3>
            <p class="ui-card-subtitle">Editable rows for builders and configuration screens.</p>
        </div>
        <button class="btn btn-primary btn-sm" type="button" data-ui-add-row>Add row</button>
    </div>
    <div class="table-responsive">
        <table class="table align-middle ui-input-table mb-0">
            <thead>
                <tr>
                    <th>Field Name</th>
                    <th>Field Type</th>
                    <th>Required</th>
                    <th>Sort Order</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody data-ui-input-table-body>
                <tr>
                    <td><input class="form-control form-control-sm" value="Full Name" /></td>
                    <td><select class="form-select form-select-sm"><option>Text</option><option>Email</option><option>Date</option></select></td>
                    <td><input class="form-check-input" type="checkbox" checked /></td>
                    <td><input class="form-control form-control-sm" type="number" value="1" /></td>
                    <td class="text-end"><button class="btn btn-light btn-sm ui-icon-button text-danger" type="button" data-ui-remove-row><i class="fa-solid fa-trash" aria-hidden="true"></i></button></td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="ui-table-footer">
        <span class="text-secondary">Row validation messages should appear inline.</span>
        <button class="btn btn-primary btn-sm" type="button">Save table</button>
    </div>
</div>
