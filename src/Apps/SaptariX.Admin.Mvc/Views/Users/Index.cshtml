@using SaptariX.Admin.Mvc.ViewModels.Users
@using SaptariX.Platform.AccessControl.Permissions
@model UserListViewModel
@{
    ViewData["Title"] = "Users";
    ViewData["ActiveMenu"] = "/Users";
    var formModel = UserFormViewModel.Empty(Model.OrganizationId);
    var permissionsModel = UserPermissionViewModel.Empty(Model.OrganizationId);
}

<section class="page-section users-page"
         data-users-root
         data-organization-id="@Model.OrganizationId"
         data-list-url="/Users/List"
         data-get-url="/Users/GetById"
         data-create-url="/Users/Create"
         data-update-url="/Users/Update"
         data-delete-url="/Users/SoftDelete"
         data-permissions-url="/Users/GetPermissions"
         data-save-permissions-url="/Users/SavePermissions">
    @Html.AntiForgeryToken()

    <div class="section-header">
        <div>
            <p class="section-kicker">Identity</p>
            <h1>Users</h1>
            <p class="section-summary">Organization-scoped user management, role assignment, and direct permission overrides.</p>
        </div>
        <span class="permission-pill">@PlatformPermissions.UsersView</span>
    </div>

    <div class="users-alert-host" data-users-alert></div>

    <ul class="nav nav-tabs users-tabs" id="usersTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="users-list-tab" data-bs-toggle="tab" data-bs-target="#users-list-pane" type="button" role="tab" aria-controls="users-list-pane" aria-selected="true">
                User List
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="users-form-tab" data-bs-toggle="tab" data-bs-target="#users-form-pane" type="button" role="tab" aria-controls="users-form-pane" aria-selected="false">
                Create User
            </button>
        </li>
    </ul>

    <div class="tab-content users-tab-content" id="usersTabsContent">
        <div class="tab-pane fade show active" id="users-list-pane" role="tabpanel" aria-labelledby="users-list-tab" tabindex="0">
            <div class="card users-card">
                <div class="card-header users-card-header">
                    <div>
                        <h2 class="users-card-title">User List</h2>
                        <p class="users-card-subtitle">Search, filter, sort, and manage organization users.</p>
                    </div>
                    <form class="users-filter sx-table-filter-row" data-users-filter-form>
                        <div class="input-group input-group-sm users-search sx-table-filter-search">
                            <span class="input-group-text">Search</span>
                            <input class="form-control form-control-sm" type="search" name="Search" placeholder="Name, email, or mobile" autocomplete="off" />
                        </div>
                        <select class="form-select form-select-sm users-status-filter sx-table-filter-select" name="Status" aria-label="Status filter">
                            <option value="">All statuses</option>
                            <option value="Active">Active</option>
                            <option value="Pending">Pending</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <div class="sx-table-filter-actions">
                            <button class="btn btn-primary btn-sm" type="submit">Apply</button>
                            <button class="btn btn-outline-secondary btn-sm" type="button" data-users-clear-filters>Reset</button>
                        </div>
                    </form>
                </div>
                <div class="card-body p-0">
                    <div class="users-loading-state d-none" data-users-loading>
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>Loading users</span>
                    </div>
                    <div id="usersListHost" data-users-list-host>
                        <partial name="_UserList" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="users-form-pane" role="tabpanel" aria-labelledby="users-form-tab" tabindex="0">
            <partial name="_UserForm" model="formModel" />
        </div>
    </div>

    <div id="userPermissionsDrawerHost" data-user-permissions-host>
        <partial name="_UserPermissionsDrawer" model="permissionsModel" />
    </div>

    <div class="modal fade" id="userDeleteModal" tabindex="-1" aria-labelledby="userDeleteModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content users-confirm-modal">
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="userDeleteModalTitle">Delete User</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this user?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger btn-sm" data-users-confirm-delete>Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/users.js" asp-append-version="true"></script>
}
