@using SaptariX.Admin.Mvc.ViewModels.Users
@model UserListViewModel
@{
    ViewData["Title"] = "Users";
    ViewData["ActiveMenu"] = "/Users";
    ViewData["HideBreadcrumb"] = true;
    var formModel = UserFormViewModel.Empty(Model.OrganizationId);
    var permissionsModel = UserPermissionViewModel.Empty(Model.OrganizationId);
    var rolesModel = UserRoleViewModel.Empty(Model.OrganizationId);
}

<section class="page-section users-page organizations-page access-page"
         data-users-root
         data-organization-id="@Model.OrganizationId"
         data-list-url="/Users/List"
         data-get-url="/Users/GetById"
         data-create-url="/Users/Create"
         data-update-url="/Users/Update"
         data-delete-url="/Users/SoftDelete"
         data-roles-url="/Users/GetRoles"
         data-save-roles-url="/Users/SaveRoles"
         data-permissions-url="/Users/GetPermissions"
         data-save-permissions-url="/Users/SavePermissions">
    @Html.AntiForgeryToken()

    <div class="section-header organizations-page-header">
        <div class="organizations-page-titlebar">
            <button type="button" class="organizations-back-button d-none" data-users-back-to-list aria-label="Back to user list">
                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            </button>
            <h1>Users</h1>
        </div>
        <div class="organizations-page-actions">
            <button type="button" class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" data-users-open-create>
                <i class="fa-solid fa-plus" aria-hidden="true"></i>
                <span>Create User</span>
            </button>
        </div>
    </div>

    <div class="users-alert-host" data-users-alert></div>

    <div class="organizations-content-stack">
        <div data-users-list-panel>
            <div class="card users-card organizations-card">
                <div class="card-body organizations-list-body p-0">
                    <form class="organizations-filter access-list-filter sx-form-compact" data-users-filter-form>
                        <div class="organizations-filter-field organizations-filter-search">
                            <label class="visually-hidden" for="UsersSearch">Search users</label>
                            <div class="input-group input-group-sm sx-table-filter-search">
                                <span class="input-group-text" aria-hidden="true"><i class="fa-solid fa-magnifying-glass"></i></span>
                                <input class="form-control form-control-sm" id="UsersSearch" type="search" name="Search" placeholder="Search by name, email, or mobile" autocomplete="off" />
                            </div>
                        </div>
                        <div class="organizations-filter-field">
                            <label class="visually-hidden" for="UsersStatus">Status</label>
                            <select class="form-select form-select-sm sx-table-filter-select" id="UsersStatus" name="Status" aria-label="Status filter" data-sx-select-minimal>
                                <option value="">All statuses</option>
                                <option value="Active">Active</option>
                                <option value="Pending">Pending</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="sx-table-filter-actions organizations-filter-actions">
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-graphite" type="submit"><i class="fa-solid fa-filter" aria-hidden="true"></i><span>Apply</span></button>
                            <button class="ui-adv-btn ui-adv-btn-elevated ui-adv-btn-orange" type="button" data-users-clear-filters><i class="fa-solid fa-rotate-left" aria-hidden="true"></i><span>Reset</span></button>
                        </div>
                    </form>
                    <div class="users-loading-state d-none" data-users-loading>
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>Loading users</span>
                    </div>
                    <div id="usersListHost" data-users-list-host>
                        <partial name="_UserList" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-none" data-users-form-panel>
            <partial name="_UserForm" model="formModel" />
        </div>
    </div>

    <div id="userPermissionsDrawerHost" data-user-permissions-host>
        <partial name="_UserPermissionsDrawer" model="permissionsModel" />
    </div>

    <div id="userRolesDrawerHost" data-user-roles-host>
        <partial name="_UserRolesDrawer" model="rolesModel" />
    </div>

    <div class="modal fade" id="userDeleteModal" tabindex="-1" aria-labelledby="userDeleteModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content users-confirm-modal">
                <div class="modal-header">
                    <h2 class="modal-title fs-6" id="userDeleteModalTitle">Delete User</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete this user?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger btn-sm" data-users-confirm-delete>Yes, Delete</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/modules/users.js" asp-append-version="true"></script>
}
