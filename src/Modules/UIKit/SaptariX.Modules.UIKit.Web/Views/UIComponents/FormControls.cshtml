@model UiComponentPageDto

<section class="page-section ui-kit-page" data-ui-kit>
    <partial name="UIComponents/_UiPageHeader" model="Model" />

    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <div class="card ui-demo-card">
                <div class="card-header"><h2 class="ui-card-title">Basic Inputs</h2></div>
                <div class="card-body">
                    <partial name="UIComponents/_UiFormInput" />
                    <div class="row g-3">
                        <div class="col-md-6"><input class="form-control form-control-sm" type="email" placeholder="Email input" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" type="password" placeholder="Password input" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" type="number" placeholder="Number input" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" type="tel" placeholder="Mobile input" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" type="search" placeholder="Search input" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" value="Disabled input" disabled /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" value="Readonly input" readonly /></div>
                        <div class="col-md-6">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">@@</span>
                                <input class="form-control" placeholder="Input with icon" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card ui-demo-card">
                <div class="card-header"><h2 class="ui-card-title">Advanced Inputs</h2></div>
                <div class="card-body">
                    <partial name="UIComponents/_UiSelect" />
                    <partial name="UIComponents/_UiTextarea" />
                    <partial name="UIComponents/_UiDateInput" />
                    <input class="form-control form-control-sm mb-3" type="datetime-local" />
                    <partial name="UIComponents/_UiFileUpload" />
                    <div class="ui-image-placeholder mb-3">Image upload placeholder</div>
                    <partial name="UIComponents/_UiToggleSwitch" />
                    <partial name="UIComponents/_UiCheckbox" />
                    <partial name="UIComponents/_UiRadioGroup" />
                    <div class="mt-3">
                        <input class="form-control form-control-sm is-invalid" value="bad-email" />
                        <div class="invalid-feedback">Email is not valid.</div>
                    </div>
                    <div class="mt-3">
                        <input class="form-control form-control-sm is-valid" value="valid value" />
                        <div class="valid-feedback">Looks good.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card ui-demo-card mt-3">
        <div class="card-header"><h2 class="ui-card-title">Layout Examples</h2></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Single column</label>
                    <input class="form-control form-control-sm" placeholder="Full width field" />
                </div>
                <div class="col-12 col-lg-8">
                    <label class="form-label">Two column compact form</label>
                    <div class="row g-2">
                        <div class="col-md-6"><input class="form-control form-control-sm" placeholder="First name" /></div>
                        <div class="col-md-6"><input class="form-control form-control-sm" placeholder="Last name" /></div>
                    </div>
                </div>
            </div>
            <div class="ui-sticky-footer mt-3">
                <button class="btn btn-primary btn-sm" type="button">Save</button>
                <button class="btn btn-outline-secondary btn-sm" type="button">Cancel</button>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        @foreach (var example in Model.Examples)
        {
            <div class="col-12 col-lg-4"><partial name="UIComponents/_UiCodePreview" model="example" /></div>
        }
    </div>
</section>
