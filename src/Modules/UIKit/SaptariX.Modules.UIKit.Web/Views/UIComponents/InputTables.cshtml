@model UiComponentPageDto

<section class="page-section ui-kit-page" data-ui-kit>
    <partial name="UIComponents/_UiPageHeader" model="Model" />

    <partial name="UIComponents/_UiInputTable" />

    <div class="row g-3 mt-1">
        <div class="col-12 col-xl-6">
            <div class="card ui-demo-card">
                <div class="card-header"><h2 class="ui-card-title">Pricing/Input Table</h2></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle ui-input-table mb-0">
                            <thead><tr><th>Plan Name</th><th>Monthly Price</th><th>Yearly Price</th><th>Status</th><th></th></tr></thead>
                            <tbody>
                                <tr><td><input class="form-control form-control-sm" value="Premium" /></td><td><input class="form-control form-control-sm" type="number" value="99" /></td><td><input class="form-control form-control-sm" type="number" value="999" /></td><td><select class="form-select form-select-sm"><option>Active</option></select></td><td><partial name="UIComponents/_UiActionButtons" /></td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card ui-demo-card">
                <div class="card-header"><h2 class="ui-card-title">Dynamic Form Builder Table</h2></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle ui-input-table mb-0">
                            <thead><tr><th>Label</th><th>Key</th><th>Type</th><th>Placeholder</th><th>Required</th><th></th></tr></thead>
                            <tbody>
                                <tr><td><input class="form-control form-control-sm" value="Email" /></td><td><input class="form-control form-control-sm" value="email" /></td><td><select class="form-select form-select-sm"><option>Email</option></select></td><td><input class="form-control form-control-sm" value="name@example.com" /></td><td><input class="form-check-input" type="checkbox" checked /></td><td><partial name="UIComponents/_UiActionButtons" /></td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        @foreach (var example in Model.Examples)
        {
            <div class="col-12 col-lg-4"><partial name="UIComponents/_UiCodePreview" model="example" /></div>
        }
    </div>
</section>
