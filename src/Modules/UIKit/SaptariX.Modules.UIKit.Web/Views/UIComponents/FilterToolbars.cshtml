@model UiComponentPageDto

<section class="page-section ui-kit-page sx-page" data-ui-kit>
    <partial name="UIComponents/_UiPageHeader" model="Model" />

    <div class="card sx-card">
        <div class="card-header">
            <h2 class="sx-card-title">Filter Toolbar Component</h2>
            <p class="sx-card-subtitle">Reusable search, status, type, date range, organization/app, reset, apply, and create controls.</p>
        </div>
        <div class="card-body">
            <partial name="UIComponents/_UiFilterToolbar" />
        </div>
    </div>

    <div class="card sx-card sx-card-compact">
        <div class="card-body">
            <h2 class="sx-card-title">Responsive Behavior</h2>
            <p class="sx-card-subtitle">Desktop uses a horizontal row, tablet switches to two columns, and mobile stacks all controls with full-width buttons.</p>
        </div>
    </div>

    <div class="row g-3">
        @foreach (var example in Model.Examples)
        {
            <div class="col-12 col-lg-4"><partial name="UIComponents/_UiCodePreview" model="example" /></div>
        }
    </div>
</section>
